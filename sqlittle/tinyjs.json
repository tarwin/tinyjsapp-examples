{
  "name": "sqlittle",
  "title": "SQLittle",
  "size": "1080x700",
  "id": "art.tarwin.sqlittle",
  "version": "0.1.4",
  "update": {
    "url": "https://raw.githubusercontent.com/tarwin/tinyjsapp-examples/main/_builds/sqlittle/manifest.json",
    "auto": "daily"
  },
  "backend": "backend/main.ts",
  "fileExtensions": [
